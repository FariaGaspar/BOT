# ========== Email (resumo do dia seguinte) ==========
# O botão "Resumo por email" envia para EMAIL_RESUMO_DESTINO.
#
# --- OPÇÃO A: Microsoft Graph (quando SMTP está desativado no Office 365) ---
# Um administrador cria uma app no Azure AD e preenche em baixo. Ver EMAIL_ENVIO.md.
# GRAPH_TENANT_ID=
# GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET=
# GRAPH_SEND_AS=joao.gaspar@pragosa.pt
#
# --- OPÇÃO B: Gmail (mais simples, sem precisar de admin) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu.email@gmail.com
# SMTP_PASSWORD=<palavra-passe de aplicação em https://myaccount.google.com/apppasswords>
#
# --- OPÇÃO C: Office 365 SMTP (só se o admin ativar SMTP AUTH) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=joao.gaspar@pragosa.pt
SMTP_PASSWORD=

EMAIL_RESUMO_DESTINO=joao.gaspar@pragosa.pt
